# Copy to .env and keep your own secret (never commit .env).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Optional: first login on a fresh DB only (skipped if any users_auth row exists).
# Defaults if unset: admin@gmail.com / admin123
# BOOTSTRAP_ADMIN_EMAIL=admin@gmail.com
# BOOTSTRAP_ADMIN_PASSWORD=admin123

# TEMPORARY: set to 1 to skip the login page (auto-login). Set to 0 or remove to restore auth.
# DISABLE_AUTH=1
